{
  "name": "@ephemere/db",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./factory": {
      "types": "./src/factory.ts",
      "default": "./src/factory.ts"
    }
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@paralleldrive/cuid2": "^2.2.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@ephemere/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3"
  }
}

{
  "version": 2,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile --filter @ephemere/api...",
  "buildCommand": "cd ../.. && pnpm --filter @ephemere/api build",
  "outputDirectory": "dist",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096"
    }
  },
  "functions": {
    "dist/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.js"
    }
  ]
}

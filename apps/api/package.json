{
  "name": "@ephemere/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 127.0.0.1 --port 4001 --env-file .env --install-skills false",
    "build": "tsc --skipLibCheck && tsc-alias",
    "deploy": "wrangler deploy",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "@ephemere/db": "workspace:*",
    "@ephemere/lib": "workspace:*",
    "@tsndr/cloudflare-worker-jwt": "^2.5.4",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "razorpay": "^2.9.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@ephemere/typescript-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.96.0"
  }
